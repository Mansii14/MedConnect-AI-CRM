# Database Connection URL (PostgreSQL, MySQL, or SQLite)
# Defaults to SQLite if left empty: sqlite:///./hcp_crm.db
# DATABASE_URL=postgresql://user:password@localhost:5432/hcp_crm

# Groq Cloud API Key (Mandatory for LangGraph and entity extraction)
GROQ_API_KEY=your_groq_api_key_here

# LLM Model Name (Gemma or Llama)
MODEL_NAME=gemma2-9b-it

# Secret Key for JWT Token Signatures (change in production)
SECRET_KEY=supersecret_ai_first_crm_key_for_development
